{
    "name": "VFA Documentation Standards",
    "short_name": "VFA Docs",
    "version": "1.0.0",
    "description": "Provides organization documentation standards inline on EMSCharts fields.",
    "manifest_version": 3,
    "minimum_chrome_version": "88",
    "browser_specific_settings": {
        "gecko": {
            "id": "vfa-documentation-standards@coder-weez.github.io",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    },
    "icons": {
        "16": "icon_16.png",
        "48": "icon_48.png",
        "128": "icon_128.png"
    },
    "permissions": [
        "activeTab"
    ],
    "host_permissions": [
        "https://*.emscharts.com/pr/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://*.emscharts.com/pr/page1.cfm*",
                "https://*.emscharts.com/pr/page2.cfm*",
                "https://*.emscharts.com/pr/page3.cfm*",
                "https://*.emscharts.com/pr/page4.cfm*",
                "https://*.emscharts.com/pr/page5.cfm*",
                "https://*.emscharts.com/pr/page7.cfm*",
                "https://*.emscharts.com/pr/page8.cfm*",
                "https://*.emscharts.com/pr/page9.cfm*"
            ],
            "js": [
                "docs.js",
                "docassist.js"
            ],
            "run_at": "document_end",
            "css": [
                "docassist.css"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["VFADocumentationStandards.pdf"],
            "matches": ["https://*.emscharts.com/*"]
        }
    ],
    "action": {
        "default_title": "VFA Documentation Standards",
        "default_icon": {
            "16": "icon_16.png",
            "48": "icon_48.png",
            "128": "icon_128.png"
        }
    }
}
